# Ignore agent configs & internal workspace data
.agents/
scratch/
skills-lock.json
.claude/
**/.claude/

# Local secrets
.env
.env.*
!.env.example

# Ignore raw/temp directories
extracted_assets/
fondos-landing codex/
fotos-amanda-generadas/
fotos-amanda-referencia/
copys banner/

# Ignore raw camera/screenshot assets in root
*.jpeg
*.jpg
*.JPG
*.png
!logo.png
!favicon-*.png
!apple-touch-icon.png
!fondos-landing/
!fondos-landing/*.jpg
!banners/
!banners/*.png

# Ignore video outputs
*.mov
*.mp4
!1.mp4
!2.mp4
!videos/
!videos/*.mp4
!videos/*.jpg
!videos/*.webp
!videos-testimonios/
!videos-testimonios/*.mp4
!videos-testimonios/*.webp

# Ignore OS files
.DS_Store
**/.DS_Store
Thumbs.db
._*
**/._*
